#+ Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

#+ C extensions
*.so

#+ Distribution / packaging
build/
dist/
*.egg-info/
eggs/
.eggs/

#+ Installer logs
pip-log.txt
pip-delete-this-directory.txt

#+ Unit test / coverage reports
.tox/
.cover
.coverage
.coverage.*
.pytest_cache/
htmlcov/

#+ Virtual environments
venv/
ENV/
env/
.env
.venv/
venv.bak/

#+ pyenv
.python-version

#+ Editor and IDE
.vscode/
.idea/
*.iml

#+ macOS
.DS_Store

#+ Mypy / profiling
.mypy_cache/
profile_default/
ipython_config.py

#+ PyInstaller
#+  Usually these files are written by a python script from a template
#+  before PyInstaller builds the exe, so as to inject date/other infos into it.
.manifest
.spec

#+ Local environment and secrets
.env.local
.env.*.local

#+ Coverage / reports
coverage.xml
*.cover

#+ Backup files
*~
